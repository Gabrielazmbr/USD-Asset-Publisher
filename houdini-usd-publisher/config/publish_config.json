{
  "studio": "YourStudio",
  "pipeline_version": "1.0",
  "export_format": "usda",
  "assets_root": "assets",
  "validators": {
    "DefaultPrimValidator": {
      "enabled": true,
      "auto_fix": true
    },
    "MetadataValidator": {
      "enabled": false,
      "auto_fix": false,
      "required_fields": [
        "asset_name",
        "version"
      ]
    },
    "VariantSetValidator": {
      "enabled": false,
      "required_sets": {
        "geo": [
          "pig",
          "toy",
          "squab",
          "tommy",
          "capy"
        ]
      }
    },
    "KindValidator": {
      "enabled": false,
      "auto_fix": false
    },
    "MaterialValidator": {
      "enabled": false
    },
    "UpAxisValidator": {
      "enabled": false,
      "auto_fix": false,
      "expected_axis": "Y"
    },
    "FileReferenceValidator": {
      "enabled": false
    },
    "NamingConventionValidator": {
      "enabled": false,
      "naming_style": "snake_case",
      "allow_leading_underscore": false,
      "allow_trailing_underscore": false,
      "allow_double_underscore": false,
      "reserved_names": [
        "default",
        "root"
      ]
    }
  }
}